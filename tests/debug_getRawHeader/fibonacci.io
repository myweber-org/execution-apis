
fib := method(n,
    memo := Map clone
    memo atPut(0, 0)
    memo atPut(1, 1)
    
    fibRec := method(k,
        if(memo hasKey(k),
            memo at(k),
            result := fibRec(k-1) + fibRec(k-2)
            memo atPut(k, result)
            result
        )
    )
    
    fibRec(n)
)

"Fibonacci of 10: " print
fib(10) println

"Fibonacci of 20: " print
fib(20) println
fibonacci := Object clone
fibonacci cache := Map clone

fibonacci get := method(n,
    if (self cache hasKey(n),
        return self cache at(n)
    )
    
    if (n <= 1,
        result := n
    ,
        result := self get(n - 1) + self get(n - 2)
    )
    
    self cache atPut(n, result)
    result
)

fibonacci sequence := method(n,
    result := List clone
    for(i, 0, n, result append(self get(i)))
    result
)

fibonacci clearCache := method(
    self cache = Map clone
)
fibonacci := method(n,
    memo := Map clone
    memo atPut(0, 0)
    memo atPut(1, 1)
    
    fib := block(n,
        if(memo hasKey(n), return memo at(n))
        result := fib call(n - 1) + fib call(n - 2)
        memo atPut(n, result)
        result
    )
    
    fib call(n)
)

for(i, 0, 10, fibonacci(i) println)

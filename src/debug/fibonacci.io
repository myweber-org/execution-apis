    cache := Map clone
    cache atPut(0, 0)
    cache atPut(1, 1)
    
    fibInternal := method(n,
        if(cache hasKey(n), return cache at(n))
        result := fibInternal(n - 1) + fibInternal(n - 2)
        cache atPut(n, result)
        result
    )
    
    fibInternal(n)
)

